# Start closed: only send files required by Dockerfile COPY commands.
*

!Dockerfile
!entrypoint.sh

!app/
!app/backend/
!app/backend/**
!app/frontend/
!app/frontend/**

# Frontend build artifacts and dependencies are rebuilt fresh inside Docker.
app/frontend/node_modules/
app/frontend/build/
app/frontend/dist/

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# Local and generated files that should never enter the Docker context.
data/
data-test/
data-codex-test/
data-codex-ocr-charts/
logs/
logs-test/
logs-codex-test/
logs-codex-ocr-charts/
*.log
.env
.env.local
.git/
.gitignore
.claude/
*.bat
docker-compose.test*.yml
docker-compose.test*.yaml
CHANGELOG.md
changelog.md
CHANGES-unreleased.md
changes-unreleased.md

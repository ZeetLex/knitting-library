# User/group used for files written to /data and /logs.
PUID=99
PGID=100

# Trust forwarded headers only from these reverse proxy IPs/CIDRs.
# Leave empty for direct LAN access.
# Examples:
# TRUSTED_PROXIES=172.16.0.0/12
# TRUSTED_PROXIES=172.18.0.2,10.0.0.0/8
TRUSTED_PROXIES=

# Optional: set if the frontend/API origin differs behind your proxy.
# ALLOWED_ORIGINS=https://knitting.example.com
ALLOWED_ORIGINS=
